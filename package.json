    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "playwright-core": "^1.61.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "resend": "^6.17.2",
