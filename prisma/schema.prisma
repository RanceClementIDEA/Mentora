// ─────────────────────────────────────────────────────────────
// AlternPilot — Schéma de données Prisma
// « Le copilote du maître d'apprentissage » (TPE / PME)
// Base : PostgreSQL hébergé sur Supabase.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Connexion « poolée » (Supavisor / PgBouncer, port 6543) — utilisée par l'app.
  url       = env("DATABASE_URL")
  // Connexion directe (port 5432) — utilisée par `prisma migrate` / `prisma db push`,
  // car le pooler en mode transaction ne gère pas les migrations.
  directUrl = env("DIRECT_URL")
}

// ── Organisation : l'entreprise cliente (la TPE/PME) ────────────
model Organisation {
  id         String      @id @default(cuid())
  nom        String
  secteur    String?
  abonnement Abonnement?
  users      User[]
  alternants Alternant[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// ── User : tuteur, admin ou référent CFA ────────────────────────
model User {
  id               String        @id @default(cuid())
  email            String        @unique
  nom              String
  role             Role          @default(TUTEUR)
  // Téléphone (optionnel) pour les alertes SMS/WhatsApp.
  telephone        String?
  organisationId   String?
  organisation     Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  // Rattachement à un CFA (renseigné pour les référents CFA).
  cfaId            String?
  cfa              Cfa?          @relation(fields: [cfaId], references: [id], onDelete: SetNull)
  alternantsSuivis Alternant[]   @relation("TuteurAlternants")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([organisationId])
  @@index([cfaId])
}

// ── CFA : centre de formation (référents + diplômes suivis) ─────
model Cfa {
  id           String        @id @default(cuid())
  nom          String
  referents    User[]
  referentiels Referentiel[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Role {
  TUTEUR
  ADMIN
  CFA_REFERENT
}

// ── Alternant : l'apprenti suivi ────────────────────────────────
model Alternant {
  id               String       @id @default(cuid())
  nom              String
  email            String       @unique
  // Téléphone (optionnel) pour les alertes SMS/WhatsApp.
  telephone        String?
  organisationId   String
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  tuteurId         String
  tuteur           User         @relation("TuteurAlternants", fields: [tuteurId], references: [id])
  diplomeId        String
  diplome          Referentiel  @relation(fields: [diplomeId], references: [id])
  // Rythme d'alternance, ex : [{ "debut": "...", "fin": "...", "type": "ECOLE" | "ENTREPRISE" }]
  rythmeAlternance Json?
  missions         Mission[]
  bilans           BilanHebdo[]
  // Score de décrochage 0-100 calculé par l'IA (renseigné en V2 — Phase 10).
  scoreRisque      Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organisationId])
  @@index([tuteurId])
  @@index([diplomeId])
}

// ── Referentiel : le diplôme préparé ────────────────────────────
model Referentiel {
  id          String       @id @default(cuid())
  nom         String // ex : "BUT GEA", "Licence Pro Logistique"
  // Rattachement à un CFA (facultatif) : sert de périmètre au référent CFA.
  cfaId       String?
  cfa         Cfa?         @relation(fields: [cfaId], references: [id], onDelete: SetNull)
  competences Competence[]
  alternants  Alternant[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([cfaId])
}

// ── Competence : bloc de compétences d'un référentiel ───────────
model Competence {
  id            String      @id @default(cuid())
  intitule      String
  referentielId String
  referentiel   Referentiel @relation(fields: [referentielId], references: [id], onDelete: Cascade)
  missions      Mission[]

  @@index([referentielId])
}

// ── Mission : une carte du Kanban ───────────────────────────────
model Mission {
  id           String        @id @default(cuid())
  titre        String
  description  String
  statut       StatutMission @default(A_FAIRE)
  alternantId  String
  alternant    Alternant     @relation(fields: [alternantId], references: [id], onDelete: Cascade)
  competenceId String?
  competence   Competence?   @relation(fields: [competenceId], references: [id], onDelete: SetNull)
  echeance     DateTime?
  suggereParIA Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([alternantId])
  @@index([competenceId])
}

enum StatutMission {
  A_FAIRE
  EN_COURS
  VALIDE
}

// ── BilanHebdo : le point hebdomadaire de l'alternant ───────────
model BilanHebdo {
  id              String    @id @default(cuid())
  alternantId     String
  alternant       Alternant @relation(fields: [alternantId], references: [id], onDelete: Cascade)
  semaine         DateTime
  reussites       String
  difficultes     String
  commentaire     String? // commentaire libre de l'alternant (3e champ du formulaire)
  resumeIA        String?
  valideParTuteur Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Un seul bilan par semaine et par alternant.
  @@unique([alternantId, semaine])
  @@index([alternantId])
}

// ── Notification : message multi-canal envoyé à un user ─────────
model Notification {
  id       String   @id @default(cuid())
  userId   String
  canal    Canal    @default(EMAIL)
  contenu  String
  envoyeLe DateTime @default(now())

  @@index([userId])
}

enum Canal {
  EMAIL
  SMS
  WHATSAPP
}

// ── Abonnement : facturation Stripe, métrée à l'alternant ───────
model Abonnement {
  id                       String           @id @default(cuid())
  organisationId           String           @unique
  organisation             Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  stripeCustomerId         String?
  // Abonnement Stripe + ligne facturée : permettent de recaler la quantité
  // (nb d'alternants) en temps réel à chaque ajout/retrait.
  stripeSubscriptionId     String?
  stripeSubscriptionItemId String?
  nbAlternants             Int              @default(0)
  statut                   StatutAbonnement @default(TRIAL)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

enum StatutAbonnement {
  TRIAL
  ACTIVE
  CANCELLED
}
